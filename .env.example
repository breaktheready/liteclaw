# Required — get from @BotFather on Telegram
BOT_TOKEN=your-telegram-bot-token-here
CHAT_ID=your-telegram-chat-id-here

# tmux target (session:window.pane)
TMUX_TARGET=claude:1

# Summarizer — Tier 1: API proxy (fast, optional)
# If unavailable, LiteClaw auto-falls back to Tier 2 (Claude Code agent)
SUMMARIZER_URL=http://localhost:8080/v1
SUMMARIZER_MODEL=claude-haiku-4-5

# Summarizer — Tier 2: Claude Code agent (automatic fallback)
# Model for the hidden summarizer agent (leave empty for Claude Code default)
# SUMMARIZER_AGENT_MODEL=

# Tuning
SCROLLBACK_LINES=500
INTERMEDIATE_INTERVAL=10

# File transfer
STAGING_DIR=~/liteclaw-files
